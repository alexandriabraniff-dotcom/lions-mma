---
import MobileNav from "./MobileNav.tsx";

const isHome = Astro.url.pathname === '/';

const programs = [
  { label: "Muay Thai",       href: "/programs/muay-thai" },
  { label: "Boxing",          href: "/programs/boxing" },
  { label: "BJJ (Gi)",        href: "/programs/bjj-gi" },
  { label: "No-Gi",           href: "/programs/nogi" },
  { label: "Wrestling",       href: "/programs/wrestling" },
  { label: "MMA",             href: "/programs/mma" },
  { label: "Women's Only",    href: "/programs/womens-only" },
  { label: "Kids",            href: "/programs/kids" },
  { label: "Private Training",href: "/programs/private-training" },
];

const aboutLinks = [
  { label: "Our Team",     href: "/team" },
  { label: "Testimonials", href: "/testimonials" },
  { label: "FAQ",          href: "/faq" },
];

const navLinks = [
  { label: "Schedule",    href: "/schedule" },
  { label: "Memberships", href: "/pricing" },
  { label: "Find Us",     href: "/#find-us" },
];
---

<!-- DESIGNER CREDIT BANNER - remove only after client payment -->
{!isHome && (
  <div class="bg-iron text-smoke font-mono text-center w-full h-7 flex items-center justify-center overflow-hidden">
    <span class="hidden sm:block text-xs">Website designed by Alexandria Braniff · AlexandriaBraniff@gmail.com</span>
    <span class="sm:hidden text-[10px] truncate px-3">Website designed by Alexandria Braniff</span>
  </div>
)}

<nav
  id="site-nav"
  class={`fixed left-0 right-0 z-50 bg-void/95 backdrop-blur-sm border-b border-iron/60 ${isHome ? 'top-0' : 'top-7'}`}
  style={isHome ? 'transform: translateY(-100%); transition: transform 0.35s cubic-bezier(0.2,0,0,1);' : 'transition: transform 0.35s cubic-bezier(0.2,0,0,1);'}
>
  <div class="max-w-7xl mx-auto px-6 flex items-center justify-between h-20">

    <!-- Logo + wordmark -->
    <a href="/" class="flex items-center gap-2.5">
      <img
        src="/images/logo.png"
        alt=""
        aria-hidden="true"
        class="h-9 w-9 shrink-0"
      />
      <span class="font-display text-canvas text-xl tracking-tight leading-none">LIONS MMA</span>
    </a>

    <div class="hidden md:flex items-center gap-7">

      <!-- Home — only on non-homepage pages, first in line -->
      {!isHome && (
        <a
          href="/"
          class="relative text-sm font-body text-canvas/75 hover:text-canvas transition-colors duration-200 uppercase tracking-wide pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 hover:after:scale-x-100"
        >
          Home
        </a>
      )}

      <!-- Programs dropdown -->
      <div class="relative group">
        <button
          class="relative text-sm font-body text-canvas/75 hover:text-canvas transition-colors duration-200 uppercase tracking-wide flex items-center gap-1 pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 group-hover:after:scale-x-100"
          aria-haspopup="true"
        >
          Programs
          <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 12" fill="none">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-52 bg-vault/98 backdrop-blur-sm border border-iron/80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-10 shadow-xl">
          {programs.map((p) => (
            <a href={p.href} class="block py-2.5 px-4 text-sm text-canvas/75 hover:text-brass hover:bg-iron/30 transition-colors duration-150">
              {p.label}
            </a>
          ))}
        </div>
      </div>

      <!-- About Us dropdown -->
      <div class="relative group">
        <button
          class="relative text-sm font-body text-canvas/75 hover:text-canvas transition-colors duration-200 uppercase tracking-wide flex items-center gap-1 pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 group-hover:after:scale-x-100"
          aria-haspopup="true"
        >
          About Us
          <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 12" fill="none">
            <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-44 bg-vault/98 backdrop-blur-sm border border-iron/80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-10 shadow-xl">
          {aboutLinks.map((p) => (
            <a href={p.href} class="block py-2.5 px-4 text-sm text-canvas/75 hover:text-brass hover:bg-iron/30 transition-colors duration-150">
              {p.label}
            </a>
          ))}
        </div>
      </div>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class="relative text-sm font-body text-canvas/75 hover:text-canvas transition-colors duration-200 uppercase tracking-wide pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 hover:after:scale-x-100"
        >
          {link.href === Astro.url.pathname ? (
            <span class="text-brass">{link.label}</span>
          ) : link.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-4">
      <a href="/free-trial" class="hidden md:inline-block bg-brass text-void text-sm font-display tracking-wide uppercase px-5 py-2 hover:brightness-110 hover:scale-[1.02] transition-all duration-200">
        Train Free
      </a>
      <div class="md:hidden">
        <MobileNav client:load isHome={isHome} />
      </div>
    </div>

  </div>
</nav>

{isHome && (
  <script>
    const nav = document.getElementById('site-nav');
    function updateNav() {
      if (!nav) return;
      nav.style.transform = window.scrollY > window.innerHeight * 0.85
        ? 'translateY(0)'
        : 'translateY(-100%)';
    }
    window.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  </script>
)}
