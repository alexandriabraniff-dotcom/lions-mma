---
---

<section class="reveal py-24 bg-void" id="why-lions">
  <div class="px-6 md:px-12 lg:px-20 max-w-4xl mx-auto">

    <!-- Section label -->
    <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-12 text-center">
      THE TALE OF THE TAPE
    </p>

    <!-- Tale of the tape grid -->
    <div class="grid grid-cols-[1fr_auto_1fr] gap-x-8 md:gap-x-16 items-start">

      <!-- Left column: right-aligned stats -->
      <div class="text-right flex flex-col gap-8">
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">FOUNDED</p>
          <p class="font-display text-4xl text-canvas leading-none">2001</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">LOCATIONS</p>
          <p class="font-display text-4xl text-canvas leading-none">2</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">DISCIPLINES</p>
          <p class="font-display text-4xl text-canvas leading-none">9</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">COMMUNITY</p>
          <p class="font-display text-2xl text-canvas leading-none">FREE</p>
          <p class="font-mono text-xs text-smoke mt-1">Self-Defence Seminars</p>
        </div>
      </div>

      <!-- Center column: brass divider with EST badge -->
      <div class="relative flex flex-col items-center self-stretch">
        <div class="w-px bg-brass flex-1"></div>
        <div class="relative z-10 my-4 border border-brass px-2 py-1 bg-void text-center">
          <p class="font-mono text-xs text-brass leading-tight">EST</p>
          <p class="font-mono text-xs text-brass leading-tight">2001</p>
        </div>
        <div class="w-px bg-brass flex-1"></div>
      </div>

      <!-- Right column: left-aligned stats -->
      <div class="text-left flex flex-col gap-8">
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">YEARS TRAINING</p>
          <p class="font-display text-4xl text-brass leading-none">25+</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">STREET</p>
          <p class="font-display text-2xl text-canvas leading-none">GRANVILLE</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">COMPETITION</p>
          <p class="font-display text-2xl text-canvas leading-none">WINNINGEST</p>
          <p class="font-mono text-xs text-smoke mt-1">Team in Western Canada</p>
        </div>
        <div>
          <p class="font-mono text-xs text-smoke uppercase tracking-widest mb-1">CHARITY</p>
          <p class="font-display text-2xl text-canvas leading-none">ANNUAL</p>
          <p class="font-mono text-xs text-smoke mt-1">Fundraisers</p>
        </div>
      </div>

    </div>

    <!-- Brass rule -->
    <div class="w-full h-px bg-brass mt-16 mb-8"></div>

    <!-- Full-width statement -->
    <p class="font-body text-canvas/80 text-center max-w-2xl mx-auto">
      Since 2001, Lions MMA has built the most decorated competition team in Western Canada while welcoming thousands of students through its doors. From first-timers to professional fighters, the standard does not change.
    </p>

  </div>
</section>
