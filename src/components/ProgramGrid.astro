---
import { disciplines } from '../data/disciplines';
---

<section class="reveal py-24 bg-vault" id="programs">
  <div class="px-6 md:px-12 lg:px-20 max-w-7xl mx-auto">

    <!-- Section header -->
    <p class="font-display text-xs tracking-widest uppercase text-smoke mb-2">Disciplines</p>
    <h2 class="font-display text-5xl text-canvas">PROGRAMS</h2>

    <!-- Program grid -->
    <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-iron">
      {disciplines.map((discipline, index) => {
        const isPrivate = discipline.id === 'private';
        const isLastPrivate = discipline.slug === 'private-training';
        return (
          <a
            href={`/programs/${discipline.slug}`}
            class:list={[
              'bg-vault hover:bg-void transition-colors duration-300 group p-8 flex flex-col gap-3 relative overflow-hidden cursor-pointer',
              isLastPrivate ? 'lg:col-span-2' : '',
            ]}
          >
            <!-- Short code -->
            <span class="font-mono text-xs text-smoke tracking-widest">{discipline.short}</span>

            <!-- Brass accent line -->
            <div class="w-8 h-px bg-brass mb-2"></div>

            <!-- Discipline name -->
            <h3 class="font-display text-3xl uppercase tracking-tight text-canvas group-hover:text-brass transition-colors duration-200">
              {discipline.name}
            </h3>

            <!-- Tagline -->
            <p class="font-body text-sm text-canvas/50 group-hover:text-canvas/70 transition-colors duration-200">
              {discipline.tagline}
            </p>

            <!-- Hover arrow -->
            <span
              class="absolute bottom-8 right-8 text-brass opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0 transition-all duration-200"
              aria-hidden="true"
            >
              &rarr;
            </span>
          </a>
        );
      })}
    </div>

  </div>
</section>
