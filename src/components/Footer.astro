---
const programs = [
  { label: "Muay Thai", href: "/programs/muay-thai" },
  { label: "Boxing", href: "/programs/boxing" },
  { label: "BJJ (Gi)", href: "/programs/bjj-gi" },
  { label: "No-Gi", href: "/programs/nogi" },
  { label: "Wrestling", href: "/programs/wrestling" },
  { label: "MMA", href: "/programs/mma" },
  { label: "Women's Only", href: "/programs/womens-only" },
  { label: "Kids", href: "/programs/kids" },
  { label: "Private Training", href: "/programs/private-training" },
];

const quickLinks = [
  { label: "Schedule", href: "/schedule" },
  { label: "Pricing", href: "/pricing" },
  { label: "Team", href: "/team" },
  { label: "FAQ", href: "/faq" },
  { label: "Blog", href: "/blog" },
  { label: "Contact", href: "/contact" },
  { label: "Free Trial", href: "/free-trial" },
];
---

<footer class="bg-vault border-t border-iron">
  <div class="max-w-7xl mx-auto px-6 py-16">

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">

      <!-- Column 1: Brand -->
      <div>
        <a href="/" class="font-display text-canvas text-4xl uppercase tracking-tight block mb-4">
          Lions MMA
        </a>
        <p class="text-canvas/80 text-sm leading-relaxed mb-6">
          Training since 2001. Vancouver's premier MMA and BJJ gym.
        </p>
        <div class="flex items-center gap-4">

          <!-- Instagram -->
          <a
            href="https://www.instagram.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Lions MMA on Instagram"
            class="text-canvas/65 hover:text-brass transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="4.5" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
            </svg>
          </a>

          <!-- Facebook -->
          <a
            href="https://www.facebook.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Lions MMA on Facebook"
            class="text-canvas/65 hover:text-brass transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M18 2H15C13.6739 2 12.4021 2.52678 11.4645 3.46447C10.5268 4.40215 10 5.67392 10 7V10H7V14H10V22H14V14H17L18 10H14V7C14 6.73478 14.1054 6.48043 14.2929 6.29289C14.4804 6.10536 14.7348 6 15 6H18V2Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <!-- X / Twitter -->
          <a
            href="https://twitter.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Lions MMA on X"
            class="text-canvas/65 hover:text-brass transition-colors"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 4L10.5 12.5M4 4H7.5L20 20H16.5L10.5 12.5M4 4L10.5 12.5M20 4L13.5 11.5M13.5 11.5L10.5 12.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

        </div>
      </div>

      <!-- Column 2: Locations -->
      <div>
        <h3 class="font-display text-xs tracking-widest uppercase text-smoke mb-4">Locations</h3>
        <div class="flex flex-col gap-5">
          <div>
            <p class="font-mono text-sm text-canvas/80 leading-relaxed">
              798 Helmcken St<br />
              Vancouver, BC V6Z 1B4<br />
              <span class="text-canvas/50 text-xs">Downtown</span>
            </p>
          </div>
          <div>
            <p class="font-mono text-sm text-canvas/80 leading-relaxed">
              2301 Kingsway<br />
              Vancouver, BC V5R 5J6<br />
              <span class="text-canvas/50 text-xs">East Vancouver</span>
            </p>
          </div>
          <a
            href="tel:+16046840991"
            class="font-mono text-sm text-canvas/80 hover:text-canvas transition"
          >
            +1 604-684-0991
          </a>
        </div>
      </div>

      <!-- Column 3: Programs -->
      <div>
        <h3 class="font-display text-xs tracking-widest uppercase text-smoke mb-4">Programs</h3>
        <ul class="flex flex-col gap-2">
          {programs.map((p) => (
            <li>
              <a href={p.href} class="text-canvas/80 hover:text-canvas transition text-sm">
                {p.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Column 4: Quick Links -->
      <div>
        <h3 class="font-display text-xs tracking-widest uppercase text-smoke mb-4">Quick Links</h3>
        <ul class="flex flex-col gap-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-canvas/80 hover:text-canvas transition text-sm">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-iron mt-12 pt-6 flex flex-col sm:flex-row justify-between items-center gap-3">
      <p class="text-canvas/60 text-sm">
        &copy; 2025 Lions MMA. All rights reserved.
      </p>
      <p class="font-mono text-xs text-smoke">
        Website designed by Alexandria Braniff
      </p>
    </div>

  </div>
</footer>
