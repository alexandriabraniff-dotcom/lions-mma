---
import { schedule, DAY_LABELS, type Day } from '../data/schedule';
import { disciplines } from '../data/disciplines';
import { locations } from '../data/locations';

const locationMap = Object.fromEntries(locations.map((l) => [l.id, l]));

// Determine today's day key
const now = new Date();
const jsDay = now.getDay(); // 0=Sun, 1=Mon, ...
const dayMap: Day[] = ['sun', 'mon', 'tue', 'wed', 'thu', 'fri', 'sat'];
const todayKey: Day = dayMap[jsDay];
const todayLabel = DAY_LABELS[todayKey];

// Current time in minutes since midnight
const nowMinutes = now.getHours() * 60 + now.getMinutes();

function toMin(t: string): number {
  const [h, m] = t.split(':').map(Number);
  return h * 60 + m;
}

// Get today's sessions sorted by start time
const todaySessions = schedule
  .filter((s) => s.day === todayKey)
  .sort((a, b) => a.start.localeCompare(b.start));

// Helper: convert "HH:MM" 24h to "H:MM AM/PM"
function fmt12h(time: string): string {
  const [hStr, mStr] = time.split(':');
  const h = parseInt(hStr, 10);
  const m = mStr;
  const period = h >= 12 ? 'PM' : 'AM';
  const h12 = h % 12 === 0 ? 12 : h % 12;
  return `${h12}:${m} ${period}`;
}

// Build a discipline lookup map
const disciplineMap = Object.fromEntries(disciplines.map((d) => [d.id, d]));

// Level badge labels
const levelLabels: Record<string, string> = {
  all: 'ALL LEVELS',
  fundamentals: 'FUNDAMENTALS',
  advanced: 'ADVANCED',
  competition: 'COMPETITION',
  kids: 'KIDS',
  womens: "WOMEN'S",
};
---

<section class="pt-8 pb-24 bg-vault" id="schedule-preview">
  <div class="px-6 md:px-12 lg:px-20 max-w-7xl mx-auto">

    <!-- Header sits above both columns -->
    <h2 class="font-display text-5xl text-canvas mb-2">ON TODAY.</h2>
    <p class="font-mono text-sm text-smoke mb-6">{todayLabel.toUpperCase()}</p>

    <!-- Two columns — schedule box and image perfectly aligned -->
    <div class="grid md:grid-cols-2 gap-12 md:gap-16 items-start">

      <!-- Left: schedule list -->
      <div>
        <!-- Scrollable box -->
        <div class="h-72 overflow-y-auto border border-iron bg-void/40 scrollbar-thin">
          {todaySessions.length === 0 ? (
            <div class="h-full flex items-center justify-center px-6">
              <p class="font-body text-canvas/50 text-sm text-center">
                No classes scheduled today.
              </p>
            </div>
          ) : (
            <ul class="divide-y divide-iron">
              {todaySessions.map((session) => {
                const discipline = disciplineMap[session.discipline];
                const sessionStart = toMin(session.start);
                const sessionEnd = toMin(session.end);
                const isLive = nowMinutes >= sessionStart && nowMinutes < sessionEnd;
                return (
                  <li class={`py-4 px-5 flex flex-col gap-1 ${isLive ? 'bg-brass/10 border-l-2 border-l-brass' : ''}`}>
                    <div class="flex items-center gap-4">
                      <span class={`font-mono text-sm w-20 shrink-0 ${isLive ? 'text-brass' : 'text-canvas/60'}`}>
                        {fmt12h(session.start)}
                      </span>
                      <span class="font-display text-base uppercase text-canvas leading-tight">
                        {discipline?.name ?? session.discipline}
                      </span>
                      {isLive && (
                        <span class="ml-auto font-mono text-[9px] tracking-widest bg-brass text-void px-2 py-0.5 shrink-0">
                          LIVE
                        </span>
                      )}
                    </div>
                    <div class="flex items-center gap-3 pl-24">
                      {session.level && session.level !== 'all' && (
                        <span class="font-mono text-[10px] border border-iron text-smoke px-2 py-0.5 shrink-0">
                          {levelLabels[session.level] ?? session.level.toUpperCase()}
                        </span>
                      )}
                      <span class="font-mono text-[10px] text-brass shrink-0">
                        {locationMap[session.location]?.address ?? session.location}
                      </span>
                    </div>
                  </li>
                );
              })}
            </ul>
          )}
        </div>

        <!-- Button below -->
        <a
          href="/schedule"
          class="mt-6 inline-block bg-brass text-void font-display text-sm tracking-wider uppercase py-3 px-8 hover:brightness-110 transition-all duration-200"
        >
          SEE FULL SCHEDULE
        </a>
      </div>

      <!-- Right: image — same h-72 as scroll box, aligned perfectly -->
      <div class="hidden md:block">
        <div class="h-72 bg-void border border-iron overflow-hidden">
          <img
            src="/images/schedule-teaser.jpg"
            alt="Lions MMA training"
            class="w-full h-full object-cover opacity-60"
          />
        </div>
      </div>

    </div>
  </div>
</section>
