---
import { locations } from '../data/locations';
---

<section class="reveal py-24 bg-void" id="locations">
  <div class="px-6 md:px-12 lg:px-20 max-w-7xl mx-auto">

    <!-- Section header -->
    <h2 class="font-display text-5xl text-canvas mb-2">TWO LOCATIONS.</h2>
    <p class="font-body text-canvas/50 mb-16">Both on Granville Street.</p>

    <!-- Locations grid -->
    <div class="grid md:grid-cols-2 gap-px bg-iron">
      {locations.map((location) => (
        <div class="bg-void p-8 md:p-12">

          <!-- Street number -->
          <p class="font-display text-6xl text-canvas mb-2">{location.short}</p>

          <!-- Street name label -->
          <p class="font-mono text-xs tracking-widest text-brass mb-6">GRANVILLE</p>

          <!-- Address -->
          <p class="font-mono text-sm text-canvas/70 mb-2">{location.address}</p>
          <p class="font-mono text-sm text-canvas/70 mb-6">{location.city}</p>

          <!-- Map embed -->
          <div class="aspect-video bg-vault border border-iron mb-6 overflow-hidden">
            <iframe
              src={location.mapUrl}
              width="100%"
              height="100%"
              class="w-full h-full grayscale opacity-70 hover:opacity-100 hover:grayscale-0 transition-all duration-500"
              allowfullscreen
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title={`Map for ${location.name}`}
            ></iframe>
          </div>

          <!-- Directions link -->
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(location.full)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-xs tracking-widest uppercase text-brass hover:text-canvas transition-colors"
          >
            GET DIRECTIONS
          </a>

        </div>
      ))}
    </div>

  </div>
</section>
