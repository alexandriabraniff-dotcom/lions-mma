---
---

<section class="relative min-h-screen overflow-hidden">

  <!-- Full-bleed hero photo (replace src with client photo when available) -->
  <img
    src="https://picsum.photos/seed/lionshero/1920/1080"
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />

  <!-- Dark overlay -->
  <div class="absolute inset-0 bg-void/65 z-10"></div>

  <!-- Grain overlay -->
  <div class="grain absolute inset-0 z-20 pointer-events-none"></div>

  <!-- Bottom vignette -->
  <div class="absolute bottom-0 left-0 right-0 h-64 bg-gradient-to-t from-void to-transparent z-20"></div>

  <!-- Content — centred logo + CTAs -->
  <div class="absolute inset-0 z-30 flex flex-col items-center justify-center px-6 text-center">

    <!-- Logo (drop logo.png into public/images/ to activate) -->
    <img
      src="/images/logo.jpg"
      alt="Lions MMA"
      class="w-44 md:w-64 mb-10 mask-wipe drop-shadow-2xl"
      style="animation-delay: 0.1s"
    />

    <!-- CTA row -->
    <div class="flex gap-4 flex-wrap justify-center">
      <a
        href="/free-trial"
        class="bg-brass text-void font-display text-sm tracking-wider uppercase py-3 px-8 hover:bg-canvas transition-colors duration-200 active:translate-y-px"
      >
        TRAIN FREE · 7 DAYS
      </a>
      <a
        href="/programs"
        class="border border-canvas/40 text-canvas font-display text-sm tracking-wider uppercase py-3 px-8 hover:border-canvas transition-colors duration-200 active:translate-y-px"
      >
        VIEW PROGRAMS
      </a>
    </div>

  </div>

  <!-- Brass accent line -->
  <div class="absolute bottom-0 left-0 w-[clamp(4rem,20vw,12rem)] h-px bg-brass z-30"></div>
</section>
