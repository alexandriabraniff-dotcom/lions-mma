---
import MobileNav from "./MobileNav.tsx";

const programs = [
  { label: "Muay Thai",       href: "/programs/muay-thai" },
  { label: "Boxing",          href: "/programs/boxing" },
  { label: "BJJ (Gi)",        href: "/programs/bjj-gi" },
  { label: "No-Gi",           href: "/programs/nogi" },
  { label: "Wrestling",       href: "/programs/wrestling" },
  { label: "MMA",             href: "/programs/mma" },
  { label: "Women's Only",    href: "/programs/womens-only" },
  { label: "Kids",            href: "/programs/kids" },
  { label: "Private Training",href: "/programs/private-training" },
];

const navLinks = [
  { label: "Schedule", href: "/schedule" },
  { label: "Pricing",  href: "/pricing" },
  { label: "Team",     href: "/team" },
  { label: "FAQ",      href: "/faq" },
  { label: "Contact",  href: "/contact" },
];

const stats = [
  { value: "25+",  label: "YEARS" },
  { value: "2",    label: "LOCATIONS" },
  { value: "9",    label: "DISCIPLINES" },
  { value: "2001", label: "EST." },
];
---

<section class="relative min-h-screen">

  <!-- Background layers in overflow-hidden wrapper so overlay nav dropdowns aren't clipped -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <img
      src="https://picsum.photos/seed/lionshero/1920/1080"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-void/80"></div>
    <div class="grain absolute inset-0"></div>
    <div class="absolute bottom-0 left-0 right-0 h-72 bg-gradient-to-t from-void to-transparent"></div>
  </div>

  <!-- DESIGNER CREDIT BANNER - remove only after client payment -->
  <div class="absolute top-0 left-0 right-0 z-50 bg-iron/90 backdrop-blur-sm text-smoke text-xs font-mono text-center py-1">
    Website designed by Alexandria Braniff &mdash; AlexandriaBraniff@gmail.com
  </div>

  <!-- Hero overlay nav (sits below credit banner, visible on hero) -->
  <div class="absolute left-0 right-0 z-40" style="top: 26px;">
    <div class="max-w-7xl mx-auto px-6 md:px-10 flex items-center justify-between h-16">

      <!-- Wordmark -->
      <a href="/" class="font-display text-canvas text-2xl tracking-tight">LIONS MMA</a>

      <!-- Desktop links -->
      <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
        <div class="relative group">
          <button
            class="text-sm font-body text-canvas/65 hover:text-canvas transition-colors uppercase tracking-wide flex items-center gap-1"
          >
            Programs
            <svg class="w-3 h-3 opacity-50" viewBox="0 0 12 12" fill="none">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-2 w-52 bg-vault/95 backdrop-blur-sm border border-iron opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50">
            {programs.map((p) => (
              <a href={p.href} class="block py-2 px-4 text-sm text-canvas/75 hover:text-brass transition-colors">
                {p.label}
              </a>
            ))}
          </div>
        </div>

        {navLinks.map((link) => (
          <a href={link.href} class="text-sm font-body text-canvas/65 hover:text-canvas transition-colors uppercase tracking-wide">
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right side -->
      <div class="flex items-center gap-4">
        <a
          href="/free-trial"
          class="hidden md:inline-block border border-canvas/25 text-canvas/70 text-xs font-display tracking-wider uppercase px-4 py-2 hover:border-canvas hover:text-canvas transition-all duration-200"
        >
          Free Trial
        </a>
        <!-- Mobile hamburger -->
        <div class="md:hidden">
          <MobileNav client:load />
        </div>
      </div>

    </div>
  </div>

  <!-- Hero center content -->
  <div class="absolute inset-0 z-30 flex flex-col items-center justify-center px-6 text-center">

    <!-- Logo — mix-blend-mode: screen removes the black circular background -->
    <img
      src="/images/logo.jpg"
      alt="Lions MMA"
      class="w-36 md:w-52 mb-8 mask-wipe drop-shadow-2xl"
      style="mix-blend-mode: screen; filter: brightness(1.05); animation-delay: 0.1s;"
    />

    <!-- Eyebrow -->
    <p
      class="hero-fade font-mono text-xs tracking-[0.22em] uppercase text-canvas/45 mb-5"
      style="animation-delay: 0.5s;"
    >
      Vancouver, BC
    </p>

    <!-- Headline -->
    <h1
      class="hero-fade font-display text-[clamp(3rem,7vw,6.5rem)] uppercase tracking-tight text-canvas leading-none mb-10"
      style="animation-delay: 0.65s;"
    >
      TRAIN WITH<br class="hidden md:block" /> THE BEST.
    </h1>

    <!-- CTAs -->
    <div class="hero-fade flex gap-3 flex-wrap justify-center" style="animation-delay: 0.85s;">
      <a
        href="/free-trial"
        class="bg-brass text-void font-display text-sm tracking-wider uppercase py-3 px-8 hover:brightness-110 transition-all duration-200 active:translate-y-px"
      >
        TRAIN FREE &middot; 7 DAYS
      </a>
      <a
        href="/programs"
        class="border border-canvas/30 text-canvas/80 font-display text-sm tracking-wider uppercase py-3 px-8 hover:border-canvas hover:text-canvas hover:bg-canvas/5 transition-all duration-200 active:translate-y-px"
      >
        VIEW PROGRAMS
      </a>
    </div>

  </div>

  <!-- Bottom stats strip -->
  <div class="absolute bottom-0 left-0 right-0 z-40 border-t border-brass/25 bg-void/70 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4">
      {stats.map((stat, i) => (
        <div
          class={`flex flex-col items-center justify-center py-5 ${i < stats.length - 1 ? 'border-r border-canvas/8' : ''}`}
        >
          <span class="font-display text-2xl md:text-3xl text-brass leading-none">{stat.value}</span>
          <span class="font-mono text-[10px] tracking-[0.18em] text-smoke mt-1">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

</section>
