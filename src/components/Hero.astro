---
import MobileNav from "./MobileNav.tsx";

const programs = [
  { label: "Muay Thai",        href: "/programs/muay-thai" },
  { label: "Boxing",           href: "/programs/boxing" },
  { label: "BJJ (Gi)",         href: "/programs/bjj-gi" },
  { label: "No-Gi",            href: "/programs/nogi" },
  { label: "Wrestling",        href: "/programs/wrestling" },
  { label: "MMA",              href: "/programs/mma" },
  { label: "Women's Only",     href: "/programs/womens-only" },
  { label: "Kids",             href: "/programs/kids" },
  { label: "Private Training", href: "/programs/private-training" },
];

const aboutLinks = [
  { label: "Team",         href: "/team" },
  { label: "Testimonials", href: "/faq" },
  { label: "FAQ",          href: "/faq" },
];

const navLinks = [
  { label: "Schedule",    href: "/schedule" },
  { label: "Memberships", href: "/pricing" },
  { label: "Find Us",     href: "/contact" },
];

const stats = [
  { value: "25+",  label: "YEARS" },
  { value: "2",    label: "LOCATIONS" },
  { value: "9",    label: "DISCIPLINES" },
  { value: "2001", label: "EST." },
];
---

<!--
  Flex-column layout so content always flows: banner → nav → hero → stats.
  Nothing is absolutely positioned except the background layers,
  so buttons can never be clipped by the stats strip.
-->
<section class="relative flex flex-col min-h-screen">

  <!-- ── Background (absolute, z-0) ─────────────────────────────────────── -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
    <img
      src="https://picsum.photos/seed/lionshero/1920/1080"
      alt=""
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <!-- 92% opacity overlay → effective bg is near-pure #0D0B09 so mix-blend-mode: screen works cleanly -->
    <div class="absolute inset-0 bg-void/92"></div>
    <div class="grain absolute inset-0"></div>
    <div class="absolute bottom-0 left-0 right-0 h-80 bg-gradient-to-t from-void to-transparent"></div>
  </div>

  <!-- ── Credit banner ──────────────────────────────────────────────────── -->
  <!-- DESIGNER CREDIT BANNER - remove only after client payment -->
  <div class="relative z-50 bg-iron/90 backdrop-blur-sm text-smoke text-xs font-mono text-center py-1">
    Website designed by Alexandria Braniff · AlexandriaBraniff@gmail.com
  </div>

  <!-- ── Hero overlay nav ───────────────────────────────────────────────── -->
  <div class="relative z-40 px-6 md:px-10">
    <div class="max-w-7xl mx-auto flex items-center justify-between h-16">

      <!-- Logo -->
      <a href="/" class="flex items-center">
        <img
          src="/images/logo.png"
          alt="Lions MMA"
          class="h-16 w-16 shrink-0"
        />
      </a>

      <!-- Desktop links -->
      <nav class="hidden md:flex items-center gap-7" aria-label="Primary">

        <!-- Programs dropdown -->
        <div class="relative group">
          <button class="relative text-sm font-body text-canvas/65 hover:text-canvas transition-colors duration-200 uppercase tracking-wide flex items-center gap-1 pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 group-hover:after:scale-x-100">
            Programs
            <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 12" fill="none">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-52 bg-vault/98 backdrop-blur-sm border border-iron/80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 shadow-xl">
            {programs.map((p) => (
              <a href={p.href} class="block py-2.5 px-4 text-sm text-canvas/70 hover:text-brass hover:bg-iron/30 transition-colors duration-150">
                {p.label}
              </a>
            ))}
          </div>
        </div>

        <!-- About Us dropdown -->
        <div class="relative group">
          <button class="relative text-sm font-body text-canvas/65 hover:text-canvas transition-colors duration-200 uppercase tracking-wide flex items-center gap-1 pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 group-hover:after:scale-x-100">
            About Us
            <svg class="w-3 h-3 opacity-50 transition-transform duration-200 group-hover:rotate-180" viewBox="0 0 12 12" fill="none">
              <path d="M2 4L6 8L10 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div class="absolute top-full left-1/2 -translate-x-1/2 mt-3 w-44 bg-vault/98 backdrop-blur-sm border border-iron/80 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50 shadow-xl">
            {aboutLinks.map((p) => (
              <a href={p.href} class="block py-2.5 px-4 text-sm text-canvas/70 hover:text-brass hover:bg-iron/30 transition-colors duration-150">
                {p.label}
              </a>
            ))}
          </div>
        </div>

        {navLinks.map((link) => (
          <a
            href={link.href}
            class="relative text-sm font-body text-canvas/65 hover:text-canvas transition-colors duration-200 uppercase tracking-wide pb-0.5 after:absolute after:bottom-0 after:left-0 after:h-px after:w-full after:origin-left after:scale-x-0 after:bg-brass after:transition-transform after:duration-200 hover:after:scale-x-100"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Right: mobile nav only -->
      <div class="flex items-center">
        <div class="md:hidden">
          <MobileNav client:load />
        </div>
      </div>

    </div>
  </div>

  <!-- ── Main hero content (flex-1 centres between nav and stats) ─────────── -->
  <div class="relative z-30 flex-1 flex flex-col items-center justify-center px-6 text-center py-16 md:py-20">

    <!-- Eyebrow -->
    <p
      class="hero-fade font-mono text-xs tracking-[0.22em] uppercase text-canvas/40 mb-4"
      style="animation-delay: 0.5s;"
    >
      Vancouver, BC
    </p>

    <!-- Headline -->
    <h1
      class="hero-fade font-display text-[clamp(3rem,7vw,6.5rem)] uppercase tracking-tight text-canvas leading-none mb-10"
      style="animation-delay: 0.65s;"
    >
      TRAIN WITH<br class="hidden md:block" /> THE BEST.
    </h1>

    <!-- CTAs -->
    <div class="hero-fade flex gap-3 flex-wrap justify-center" style="animation-delay: 0.85s;">
      <a
        href="/free-trial"
        class="bg-brass text-void font-display text-sm tracking-wider uppercase py-3 px-8 hover:brightness-110 transition-all duration-200 active:translate-y-px"
      >
        TRAIN FREE · 7 DAYS
      </a>
      <a
        href="/programs"
        class="border border-canvas/30 text-canvas/80 font-display text-sm tracking-wider uppercase py-3 px-8 hover:border-brass hover:text-canvas transition-all duration-200 active:translate-y-px"
      >
        VIEW PROGRAMS
      </a>
    </div>

  </div>

  <!-- ── Stats strip (at natural bottom of flex column) ────────────────── -->
  <div class="relative z-40 border-t border-brass/20 bg-void/70 backdrop-blur-sm">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4">
      {stats.map((stat, i) => (
        <div class={`flex flex-col items-center justify-center py-5 ${i < stats.length - 1 ? 'border-r border-white/[0.07]' : ''}`}>
          <span class="font-display text-2xl md:text-3xl text-brass leading-none">{stat.value}</span>
          <span class="font-mono text-[10px] tracking-[0.18em] text-smoke mt-1">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>

</section>
