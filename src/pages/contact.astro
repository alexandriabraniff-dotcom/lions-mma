---
import Base from '../layouts/Base.astro';
---

<Base title="Contact & Locations" description="Lions MMA Vancouver. Two locations on Granville Street. Walk in anytime during class hours. Call (604) 684-0991.">
  <div class="pt-32 pb-24 max-w-7xl mx-auto px-6">

    <!-- Page header -->
    <div class="mb-16">
      <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">CONTACT & LOCATIONS</p>
      <h1 class="font-display text-6xl md:text-8xl uppercase tracking-tight text-canvas leading-none">COME IN.</h1>
      <p class="font-body text-canvas/60 mt-4 max-w-xl text-lg">Two locations. Walk in anytime during class hours.</p>
    </div>

    <!-- Location cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-20">

      <!-- Location 1 -->
      <div class="bg-vault border border-iron p-10">
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-4">LOCATION 01</p>
        <h2 class="font-display text-3xl uppercase tracking-tight text-canvas mb-6">Location 1</h2>
        <address class="not-italic mb-6">
          <p class="font-mono text-sm text-canvas/80 leading-relaxed">
            1256 Granville Street<br />
            Vancouver, BC V6Z 1M6<br />
            Canada
          </p>
        </address>
        <p class="font-mono text-sm text-canvas/80 mb-6">
          <a href="tel:+16046840991" class="hover:text-brass transition-colors">(+1) 604-684-0991</a>
        </p>
        <div class="aspect-video w-full overflow-hidden mb-6 grayscale hover:grayscale-0 transition-all duration-300">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2602.6!2d-123.1365!3d49.2785!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1256+Granville+St+Vancouver!5e0!3m2!1sen!2sca!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lions MMA Location 1"
          ></iframe>
        </div>
        <a
          href="https://maps.google.com/?q=1256+Granville+St+Vancouver+BC"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs tracking-widest uppercase text-brass hover:underline"
        >
          GET DIRECTIONS
        </a>
      </div>

      <!-- Location 2 -->
      <div class="bg-vault border border-iron p-10">
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-4">LOCATION 02</p>
        <h2 class="font-display text-3xl uppercase tracking-tight text-canvas mb-6">Location 2</h2>
        <address class="not-italic mb-6">
          <p class="font-mono text-sm text-canvas/80 leading-relaxed">
            1133 Granville Street<br />
            Vancouver, BC V6Z 1L4<br />
            Canada
          </p>
        </address>
        <p class="font-mono text-sm text-canvas/80 mb-6">
          <a href="tel:+16046840991" class="hover:text-brass transition-colors">(+1) 604-684-0991</a>
        </p>
        <div class="aspect-video w-full overflow-hidden mb-6 grayscale hover:grayscale-0 transition-all duration-300">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2602.6!2d-123.1368!3d49.2770!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2s1133+Granville+St+Vancouver!5e0!3m2!1sen!2sca!4v1"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Lions MMA Location 2"
          ></iframe>
        </div>
        <a
          href="https://maps.google.com/?q=1133+Granville+St+Vancouver+BC"
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-xs tracking-widest uppercase text-brass hover:underline"
        >
          GET DIRECTIONS
        </a>
      </div>

    </div>

    <!-- Hours note -->
    <div class="mb-16 p-8 bg-vault border border-iron">
      <p class="font-body text-canvas/60">
        Class hours vary by location and day.{' '}
        <a href="/schedule" class="text-brass hover:underline">See the full schedule</a> for exact times.
      </p>
    </div>

    <!-- Contact details -->
    <div class="mb-20 grid grid-cols-1 md:grid-cols-2 gap-12">
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-6">CONTACT</p>
        <div class="flex flex-col gap-4">
          <div>
            <p class="font-mono text-xs text-smoke mb-1">PHONE</p>
            <a href="tel:+16046840991" class="font-body text-canvas hover:text-brass transition-colors">(+1) 604-684-0991</a>
          </div>
          <div>
            <p class="font-mono text-xs text-smoke mb-1">EMAIL</p>
            <p class="font-body text-canvas/60 text-sm">For general enquiries, visit us in person or check the schedule.</p>
          </div>
        </div>
      </div>
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-6">FOLLOW</p>
        <div class="flex flex-col gap-3">
          <a
            href="https://www.instagram.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm text-canvas hover:text-brass transition-colors tracking-widest uppercase"
          >
            INSTAGRAM
          </a>
          <a
            href="https://www.facebook.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm text-canvas hover:text-brass transition-colors tracking-widest uppercase"
          >
            FACEBOOK
          </a>
          <a
            href="https://x.com/lionsmma"
            target="_blank"
            rel="noopener noreferrer"
            class="font-mono text-sm text-canvas hover:text-brass transition-colors tracking-widest uppercase"
          >
            X
          </a>
        </div>
      </div>
    </div>

    <!-- Free trial CTA -->
    <div class="border-t border-iron pt-16">
      <p class="font-body text-canvas/60 text-lg max-w-xl mb-6">
        The best way to start is to show up. Mention your name at the front desk. 7 days, on us.
      </p>
      <a
        href="/free-trial"
        class="inline-block bg-brass text-void font-display tracking-wider uppercase px-10 py-4 text-sm hover:bg-canvas hover:text-void transition-colors"
      >
        CLAIM YOUR FREE TRIAL
      </a>
    </div>

  </div>
</Base>
