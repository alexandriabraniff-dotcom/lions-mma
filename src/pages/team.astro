---
import Base from '../layouts/Base.astro';
import { team } from '../data/team';

const headInstructors = team.filter(c => c.role.includes('Head Instructor'));
const otherInstructors = team.filter(c => !c.role.includes('Head Instructor'));
---

<Base title="The Team" description="Meet the coaches at Lions MMA Vancouver. Head instructors and staff across striking, grappling, kids, and conditioning.">
  <div class="pt-32 pb-24 max-w-7xl mx-auto px-6">

    <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">THE TEAM</p>
    <h1 class="font-display text-7xl md:text-9xl uppercase tracking-tight text-canvas leading-none">COACHES.</h1>
    <p class="font-body text-canvas/60 mt-4">The instructors who built this gym.</p>

    <!-- Head Instructors -->
    <div class="mt-20">
      <p class="font-mono text-xs tracking-widest uppercase text-smoke border-b border-iron pb-2 mb-8">HEAD INSTRUCTORS</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-iron">
        {headInstructors.map(coach => (
          <div class="bg-vault p-8">
            <div class="w-full aspect-[4/5] bg-iron mb-6 flex items-end p-3">
              <div class="font-mono text-xs text-smoke">PHOTO COMING SOON</div>
            </div>
            <p class="font-display text-2xl uppercase text-canvas">{coach.name}</p>
            <p class="font-mono text-xs text-brass tracking-wider uppercase mt-1">{coach.role}</p>
            {coach.credentials && (
              <p class="font-mono text-xs text-smoke mt-1">{coach.credentials}</p>
            )}
            <p class="font-body text-sm text-canvas/60 mt-4 leading-relaxed">{coach.bio}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Other Instructors -->
    <div class="mt-20">
      <p class="font-mono text-xs tracking-widest uppercase text-smoke border-b border-iron pb-2 mb-8">INSTRUCTORS</p>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-px bg-iron">
        {otherInstructors.map(coach => (
          <div class="bg-vault p-8">
            <div class="w-full aspect-square bg-iron mb-6 flex items-end p-3">
              <div class="font-mono text-xs text-smoke">PHOTO COMING SOON</div>
            </div>
            <p class="font-display text-2xl uppercase text-canvas">{coach.name}</p>
            <p class="font-mono text-xs text-brass tracking-wider uppercase mt-1">{coach.role}</p>
            {coach.credentials && (
              <p class="font-mono text-xs text-smoke mt-1">{coach.credentials}</p>
            )}
            <p class="font-body text-sm text-canvas/60 mt-4 leading-relaxed">{coach.bio}</p>
          </div>
        ))}
      </div>
    </div>

    <p class="font-mono text-xs text-smoke/50 mt-16">Coach roster and photos are placeholder. Confirm current roster with the gym.</p>

  </div>
</Base>
