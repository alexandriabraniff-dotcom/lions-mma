---
import Base from '../layouts/Base.astro';
import { faq } from '../data/faq';
import { testimonials } from '../data/testimonials';
---

<Base title="FAQ" description="Frequently asked questions about Lions MMA Vancouver. Getting started, training, membership, and gym culture.">
  <div class="pt-32 pb-24 max-w-4xl mx-auto px-6">

    <!-- Page header -->
    <div class="mb-16">
      <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">FAQ</p>
      <h1 class="font-display text-6xl md:text-8xl uppercase tracking-tight text-canvas leading-none">QUESTIONS.</h1>
    </div>

    <!-- FAQ categories -->
    {faq.map(section => (
      <section class="mb-14">
        <h2 class="font-display text-3xl md:text-4xl uppercase tracking-tight text-canvas mb-8">{section.category}</h2>
        <div>
          {section.items.map(item => (
            <details class="border-b border-iron group">
              <summary class="font-body text-lg text-canvas cursor-pointer py-5 flex items-start justify-between gap-4 hover:text-brass transition-colors list-none">
                <span>{item.q}</span>
                <span class="font-mono text-xl leading-none shrink-0 mt-0.5 select-none group-open:hidden">+</span>
                <span class="font-mono text-xl leading-none shrink-0 mt-0.5 select-none hidden group-open:block">&#8722;</span>
              </summary>
              <p class="font-body text-canvas/80 leading-relaxed pt-2 pb-6 max-w-2xl">{item.a}</p>
            </details>
          ))}
        </div>
      </section>
    ))}

  </div>

  <!-- Google Reviews -->
  <section class="border-t border-iron bg-vault py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="mb-14">
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">Google Reviews</p>
        <h2 class="font-display text-5xl md:text-6xl uppercase tracking-tight text-canvas leading-none">WHAT MEMBERS SAY.</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-iron">
        {testimonials.map((t) => (
          <div class="bg-vault p-8 flex flex-col gap-4">
            <span class="font-display text-4xl text-brass/25 leading-none">&ldquo;</span>
            <blockquote class="font-body text-canvas/80 text-sm leading-relaxed flex-1">{t.quote}</blockquote>
            <div class="flex items-center gap-3 pt-2 border-t border-iron">
              <div class="flex gap-0.5">
                {[1,2,3,4,5].map(() => (
                  <svg width="12" height="12" viewBox="0 0 12 12" fill="#C09A3C"><path d="M6 1l1.4 2.8 3.1.4-2.2 2.2.5 3.1L6 8l-2.8 1.5.5-3.1L1.5 4.2l3.1-.4z"/></svg>
                ))}
              </div>
              <p class="font-mono text-xs text-smoke">{t.name} · {t.detail}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  details[open] > summary {
    color: var(--color-brass, #c9a84c);
  }
</style>
