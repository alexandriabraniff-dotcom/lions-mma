---
import Base from '../layouts/Base.astro';
import { testimonials } from '../data/testimonials';
---

<Base title="Testimonials" description="What members say about Lions MMA Vancouver. Real reviews from our community.">
  <div class="pt-32 pb-24 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">

    <!-- Page header -->
    <div class="mb-20">
      <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">Member Reviews</p>
      <h1 class="font-display text-6xl md:text-8xl uppercase tracking-tight text-canvas leading-none">TESTIMONIALS.</h1>
      <p class="font-body text-canvas/60 mt-4 max-w-xl text-lg">
        Words from the people on the mats. Real members, real results.
      </p>
    </div>

    <!-- Testimonial grid — 2 columns, large image zones -->
    <div class="grid md:grid-cols-2 gap-6">
      {testimonials.map((t) => (
        <a
          href={t.reviewUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="group flex flex-col bg-vault border border-iron hover:border-brass/50 transition-colors duration-300"
        >
          <!-- Image zone — tall, ready for photos -->
          <div class="h-80 md:h-96 relative overflow-hidden bg-iron/40 border-b border-iron group-hover:bg-iron/60 transition-colors duration-300 flex flex-col items-center justify-center gap-3">
            {t.image ? (
              <img
                src={t.image}
                alt={t.name}
                class="absolute inset-0 w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500"
              />
            ) : (
              <>
                <svg class="w-12 h-12 text-smoke/15" viewBox="0 0 24 24" fill="none">
                  <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                <p class="font-mono text-[10px] tracking-widest text-smoke/25 uppercase">Photo Coming Soon</p>
              </>
            )}
          </div>

          <!-- Quote + attribution -->
          <div class="p-8 md:p-10 flex flex-col flex-1">
            <span class="font-display text-7xl leading-none text-brass/20 -mb-2 group-hover:text-brass/30 transition-colors duration-200" aria-hidden="true">&ldquo;</span>

            <blockquote class="font-body text-canvas/80 text-base leading-relaxed flex-1 mt-5">
              {t.quote}
            </blockquote>

            <div class="mt-8 pt-6 border-t border-iron flex items-center justify-between gap-4">
              <div class="flex items-center gap-4">
                <div class="w-6 h-px bg-brass shrink-0"></div>
                <div>
                  <p class="font-display text-sm uppercase tracking-widest text-canvas leading-tight">
                    {t.name}
                  </p>
                  <p class="font-mono text-[10px] tracking-widest text-smoke mt-0.5">
                    {t.detail.toUpperCase()}
                  </p>
                </div>
              </div>
              <div class="flex items-center gap-2 shrink-0">
                <span class="font-mono text-[9px] tracking-widest uppercase text-smoke/50 group-hover:text-brass/60 transition-colors duration-200 hidden sm:block">Read on Google</span>
                <svg class="w-5 h-5 text-smoke/35 group-hover:text-brass/70 transition-colors duration-200" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" opacity=".6"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" opacity=".6"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" opacity=".6"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" opacity=".6"/>
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-16 border border-iron p-10 md:p-14 flex flex-col md:flex-row items-center justify-between gap-8 bg-vault">
      <div>
        <p class="font-mono text-xs tracking-widest uppercase text-smoke mb-2">Experience it yourself</p>
        <p class="font-display text-3xl md:text-4xl uppercase leading-tight text-canvas">
          7 days free. No card required.
        </p>
      </div>
      <a
        href="/free-trial"
        class="bg-brass text-void font-display text-sm tracking-wider uppercase py-3 px-8 hover:brightness-110 transition shrink-0"
      >
        CLAIM YOUR FREE TRIAL
      </a>
    </div>

  </div>
</Base>
